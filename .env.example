# このファイルをコピーして .env を作成し、実際の接続情報を設定してください。
#   cp .env.example .env
#
# .env は .gitignore で除外されており、コミットされません（実値は共有しないこと）。

# データベース接続文字列（PostgreSQL）
# 形式: postgresql://ユーザー名:パスワード@ホスト:ポート/データベース名
# 例:   postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
#
# 注意: prisma migrate を実行する環境では、Accelerate 等のプール用URLではなく
#       「直接接続できる」接続文字列を指定してください（README 参照）。
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME"
