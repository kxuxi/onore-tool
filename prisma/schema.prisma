generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 兵種マスタ
model UnitType {
  id          Int      @id @default(autoincrement())
  name        String   @unique // 兵種名
  category    String   @default("") // 種類 (万能/歩兵/弓兵/騎兵/小型船/特殊船/軍艦/妖怪)
  goodAgainst String   @default("") // 得意兵種
  attack      Int      @default(0) // 攻撃
  defense     Int      @default(0) // 防御
  cost        String   @default("") // 雇用金 (例: 金:120)
  tech        String   @default("") // 技術
  years       String   @default("") // 年数
  reqStats    String   @default("") // 必要能力値
  facility    String   @default("") // 施設/国宝
  special     String   @default("") // 特殊攻撃
  bonus       String   @default("") // ボーナス
  updatedAt   DateTime @updatedAt
}

// 武将DB
model Warlord {
  name         String   @id // 武将名
  faction      String?  // 勢力/国
  type         String   @default("") // タイプ
  branch       String   @default("") // 兵科
  unit         String?  // 兵種
  battleAt     String?  // 戦闘時刻 (元テキスト)
  lastActionAt String?  // 最終行動時刻
  actions      String[] @default([]) // 行動履歴
  term         Int      @default(145) // 最後に登録された期番号
  updatedAt    BigInt   @default(0)
  // ランキング取り込みで反映する能力値（武力〜計略）と自己PR。すべて任意。
  power        Int?     // 武力
  intelligence Int?     // 知力
  leadership   Int?     // 統率力
  politics     Int?     // 政治力
  strategy     Float?   // 計略 (例: 102.5)
  selfPr       String?  // 自己PR
  statsRaw     String?  // 取り込み元の生テキスト（資金・兵糧など未使用項目の保全用）
}

// 戦闘履歴
model BattleRecord {
  id      Int     @id @default(autoincrement())
  line    String  @unique // 重複排除キー(戦闘時刻・場所・武将・勝敗から生成。ターン/URLの差異は無視)
  raw     String  @default("") // 元の行（表示・再解析に使用）
  time    String? // 戦闘時刻
  term    Int     @default(145) // 期番号（145期など）
  savedAt BigInt  @default(0)
}

// 国（勢力）の表示色設定（全ユーザー共有）
model FactionColor {
  faction String @id
  color   String
}

// 管理者ユーザー（自前認証・複数管理者対応。パスワードはハッシュ化して保存）
model User {
  id           Int      @id @default(autoincrement())
  username     String   @unique // ログインID
  passwordHash String // scrypt によるハッシュ（salt 同梱・平文は保存しない）
  createdAt    DateTime @default(now())
}
